{
  "name": "mage-web-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Modern browser UI for XMage (React + Vite). Built output is served by the Mage.Client.Web gateway.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "playwright test --project=chromium",
    "test:headed": "playwright test --project=chromium --headed",
    "test:ui": "playwright test --ui",
    "test:e2e": "playwright test --project=e2e",
    "test:spectate": "SPECTATE=1 playwright test --project=e2e spectate",
    "smoke": "node scripts/smoke-game.mjs",
    "clips": "node scripts/build-clips.mjs",
    "test:audit": "AUDIT=1 playwright test usability --project=chromium",
    "test:interact": "INTERACT=1 playwright test interaction-coverage --project=chromium",
    "test:gesture": "GESTURE=1 playwright test gesture-coverage --project=chromium"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "ws": "^8.21.0"
  }
}
